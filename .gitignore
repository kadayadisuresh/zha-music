# ── Secrets / environment ──────────────────────────────
# Never commit real secrets. .env.example templates stay tracked.
.env
.env.local
.env.*.local
backend/.env

# ── Python bytecode / caches ───────────────────────────
__pycache__/
*.py[cod]
*.egg-info/

# ── Python virtualenvs ─────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Backend runtime data ───────────────────────────────
# Uploaded files are user content, not source.
backend/uploads/

# ── Tooling / scratch output ───────────────────────────
.playwright-mcp/

# ── Dev/QA screenshots dropped at the repo root ────────
# Anchored with a leading slash so frontend/public images are NOT ignored.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/mobile-test-screenshots/

# ── OS / editor junk ───────────────────────────────────
.DS_Store
Thumbs.db
